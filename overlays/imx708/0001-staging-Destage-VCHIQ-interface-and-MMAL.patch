-
-static int
-vchiq_keepalive_vchiq_callback(struct vchiq_instance *instance,
-			       enum vchiq_reason reason,
-			       struct vchiq_header *header,
-			       unsigned int service_user,
-			       void *cb_data, void __user *cb_userdata)
