--- /dev/null
+++ b/drivers/platform/raspberrypi/vchiq-interface/vchiq_arm.c
@@ -0,0 +1,1477 @@
+// SPDX-License-Identifier: GPL-2.0 OR BSD-3-Clause
+/*
