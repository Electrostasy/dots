-		int slot_stalls;
-		int bulk_stalls;
-		int error_count;
-		int ctrl_tx_count;
-		int ctrl_rx_count;
-		int bulk_tx_count;
-		int bulk_rx_count;
-		int bulk_aborted_count;
-		u64 ctrl_tx_bytes;
-		u64 ctrl_rx_bytes;
-		u64 bulk_tx_bytes;
-		u64 bulk_rx_bytes;
-	} stats;
-
-	int msg_queue_read;
-	int msg_queue_write;
-	struct completion msg_queue_pop;
-	struct completion msg_queue_push;
-	struct vchiq_header *msg_queue[VCHIQ_MAX_SLOTS];
-};
